{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd growth-capacity-diagnostic-c09 && npx --yes pnpm@10.14.0 install --frozen-lockfile",
  "buildCommand": "cd growth-capacity-diagnostic-c09 && pnpm build:client",
  "outputDirectory": "growth-capacity-diagnostic-c09/dist/spa",
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/embed",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    }
  ]
}
